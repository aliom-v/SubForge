{
  "name": "@subforge/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --config ../../wrangler.toml",
    "build": "wrangler deploy --dry-run --config ../../wrangler.toml",
    "deploy": "wrangler deploy --config ../../wrangler.toml",
    "typecheck": "tsc --noEmit",
    "db:migrations:apply:local": "wrangler d1 migrations apply DB --local --config ../../wrangler.toml",
    "db:migrations:apply": "wrangler d1 migrations apply DB --remote --config ../../wrangler.toml"
  },
  "dependencies": {
    "@subforge/core": "0.1.0",
    "@subforge/shared": "0.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241022.0",
    "typescript": "^5.6.3",
    "wrangler": "^4.45.0"
  }
}
